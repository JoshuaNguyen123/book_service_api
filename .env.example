# ── Database ──────────────────────────────────────────────────────────────────
# Override the SQLite path or swap in a PostgreSQL URL
# DATABASE_URL=sqlite:///./data/app.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/bookdb

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (disabled by default)
# CORS_ORIGINS=http://localhost:3000,https://myapp.example.com

# ── Logging ───────────────────────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Ollama (AI enrichment) ────────────────────────────────────────────────────
# Point at a local instance or Ollama Cloud endpoint
OLLAMA_BASE_URL=http://localhost:11434
# Model to use for AI enrichment (must be pulled: ollama pull <model>)
OLLAMA_MODEL=llama3

# ── Google Books API (optional) ───────────────────────────────────────────────
# Without a key the Google Books source still works but is rate-limited.
# GOOGLE_BOOKS_API_KEY=your_key_here
